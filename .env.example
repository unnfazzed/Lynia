# Lynia API environment (copy to apps/api/.env for local dev)

# --- Core ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://lynia:lynia@localhost:5432/lynia?schema=public
# Explicit connection-pool tuning (applied to the datasource URL by PrismaService). Optional:
# DATABASE_CONNECTION_LIMIT defaults to a deterministic 10; DATABASE_POOL_TIMEOUT to Prisma's default.
# DATABASE_CONNECTION_LIMIT=10
# DATABASE_POOL_TIMEOUT=10

# --- Redis (BullMQ jobs + Socket.IO pub/sub + OTP counters) ---
REDIS_URL=redis://localhost:6379

# --- Cloud provider selection (chosen: gcp; azure retained as the D7 portability fallback) ---
CLOUD_PROVIDER=gcp

# Storage (object) — bucket/container name; credentials via the platform's env
STORAGE_BUCKET=lynia-media
GCP_STORAGE_PROJECT_ID=
AZURE_STORAGE_CONNECTION_STRING=

# Push (FCM-direct, portable across clouds)
# fcm = send via firebase-admin; noop (default) = log only (dev/test, and prod until FCM is provisioned).
PUSH_PROVIDER=noop
# Optional project override; on Cloud Run ADC supplies it. For local "fcm" testing, set
# GOOGLE_APPLICATION_CREDENTIALS to a service-account key path (ADC) instead of embedding a key here.
FCM_PROJECT_ID=

# Secrets are injected as env at deploy time (D7: avoid managed-identity lock-in)

# --- Observability (OpenTelemetry, swappable exporter) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=lynia-api

# --- OTP: WhatsApp Cloud API (Meta) — only needed when OTP_CHANNEL=whatsapp ---
WHATSAPP_PHONE_NUMBER_ID=        # the sender phone-number ID from the Meta app
WHATSAPP_ACCESS_TOKEN=           # secret — system-user / permanent token (Bearer)
WHATSAPP_TEMPLATE_NAME=          # the approved authentication-category OTP template name
# WHATSAPP_TEMPLATE_LANG defaults to en; WHATSAPP_GRAPH_VERSION to v21.0; base URL to graph.facebook.com.
# WHATSAPP_OTP_COPY_CODE_BUTTON defaults to "true" (Meta auth templates have a copy-code button);
# set "false" if your approved template is body-only.

# --- Other vendors (wired in later lanes) ---
SMS_GATEWAY_API_KEY=
# Mobile build vars (EAS secrets / apps/mobile/.env — consumed by app.config.ts, NOT the API):
GOOGLE_MAPS_API_KEY=             # Android Maps key (react-native-maps); iOS uses Apple Maps
# Path to the founder-supplied Firebase google-services.json (Android FCM). Provide it as an EAS
# **file** secret named GOOGLE_SERVICES_JSON, or drop the file at apps/mobile/google-services.json
# (gitignored). Required for the dev/standalone build to mint a native FCM token → live push.
GOOGLE_SERVICES_JSON=

# --- KYC: Didit (verifies Zimbabwean national IDs) ---
# stub (default, no external calls) | didit
KYC_PROVIDER=stub
DIDIT_API_KEY=                  # secret — x-api-key for every verification.didit.me/v3/* call
# Per-session config (NOT a secret): the workflow run on each session. e.g. the "Free KYC" workflow
# is ef08effc-4f57-4c16-b06f-e41c04445eec — get yours from the console (Workflows) or GET /v3/workflows/.
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=           # secret — register a v3 webhook destination; this is its secret_shared_key
DIDIT_CALLBACK_URL=             # post-verification browser redirect (success page / app deep link) — NOT the webhook
# DIDIT_BASE_URL defaults to https://verification.didit.me
# Webhook: register a webhook_version=v3 destination at URL <api>/kyc/callback; we verify the
# X-Signature-V2 HMAC (canonical body) + a 300s X-Timestamp freshness window.

# --- Local dev quickstart (no cloud) ---
# Copy to apps/api/.env, then: pnpm db:up && pnpm db:migrate && pnpm db:seed && pnpm dev
#   DATABASE_URL=postgresql://lynia:lynia@localhost:5432/lynia?schema=public
#   REDIS_URL=redis://localhost:6379
#   OTP_CHANNEL=console
# For the admin dashboard to show live data, set in apps/admin: API_BASE_URL=http://localhost:3000

# --- Auth (lane B) ---
JWT_SIGNING_SECRET=dev-insecure-secret-change-me-please
ACCESS_TTL_SECONDS=900
REFRESH_TTL_SECONDS=2592000
OTP_TTL_SECONDS=300
# E4: whatsapp (default) | sms | console (logs the code — local dev, no provider)
OTP_CHANNEL=whatsapp

# Lynia API environment (copy to apps/api/.env for local dev)

# --- Core ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://lynia:lynia@localhost:5432/lynia?schema=public

# --- Redis (BullMQ jobs + Socket.IO pub/sub + OTP counters) ---
REDIS_URL=redis://localhost:6379

# --- Cloud provider selection (D7 portability: azure primary, gcp fallback) ---
CLOUD_PROVIDER=azure

# Storage (object) — bucket/container name; credentials via the platform's env
STORAGE_BUCKET=lynia-media
AZURE_STORAGE_CONNECTION_STRING=
GCP_STORAGE_PROJECT_ID=

# Push (FCM-direct, portable across clouds)
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# Secrets are injected as env at deploy time (D7: avoid managed-identity lock-in)

# --- Observability (OpenTelemetry, swappable exporter) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=lynia-api

# --- Vendors (wired in later lanes) ---
WHATSAPP_BSP_API_KEY=
SMS_GATEWAY_API_KEY=
KYC_VENDOR_API_KEY=
GOOGLE_MAPS_API_KEY=
JWT_SIGNING_SECRET=dev-only-change-me
